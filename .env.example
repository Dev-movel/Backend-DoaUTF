# ========== AMBIENTE ==========
NODE_ENV=development
PORT=3000

# ========== BANCO DE DADOS ==========
DB_USER=seu_usuario_postgres
DB_PASS=sua_senha_postgres
DB_NAME=doautf_db
DB_HOST=localhost
DB_PORT=5432

# ========== JWT - Autenticação ==========
# Gere chaves seguras executando:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_uma_chave_aleatoria_segura_aqui
JWT_REFRESH_SECRET=gere_outra_chave_aleatoria_segura_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ========== E-MAIL - Resend ==========
# Obtenha sua chave em https://resend.com
MAIL_FROM=DoaUTF <seu_email@resend.dev>
RESEND_API_KEY=sua_chave_resend_aqui

# ========== FRONTEND ==========
# URL do frontend (ex: http://localhost:44927 para Flutter)
# Caso rode o frontend com o comando "flutter run -d chrome --web-port=3001", use http://localhost:3001
FRONTEND_URL=http://localhost:44927