# ========== AMBIENTE ==========
NODE_ENV=development
PORT=3000

# ========== BANCO DE DADOS ==========
DB_USER=seu_usuario_postgres
DB_PASS=sua_senha_postgres
DB_NAME=doautf_db
DB_HOST=localhost
DB_PORT=5432

# ========== JWT - Autenticação ==========
# Gere chaves seguras executando:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_uma_chave_aleatoria_segura_aqui
JWT_REFRESH_SECRET=gere_outra_chave_aleatoria_segura_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ========== E-MAIL - Nodemailer ==========
# Para Gmail: Ative "Senhas de app" em https://myaccount.google.com/apppasswords
# Para outros serviços: Configure conforme a documentação do Nodemailer
MAIL_SERVICE=gmail
MAIL_USER=seu_email@gmail.com
MAIL_PASS=sua_senha_de_app_do_gmail
MAIL_FROM_NAME=DoaUTF
